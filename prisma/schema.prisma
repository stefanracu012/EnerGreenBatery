generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model ContactRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  message   String
  service   String?
  package   String?
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  phone          String?
  houseSize      Float
  consumption    Float?
  recommendedKw  Float
  suggestedPkg   String
  estimatedPrice Float
  createdAt      DateTime @default(now())
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String
  icon        String
  image       String?
  packages    Package[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

type PackageProduct {
  name       String
  spec       String
  quantity   Float
  unit       String
  unitPrice  Float
  totalPrice Float
}

model Package {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  serviceId         String           @db.ObjectId
  service           Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name              String
  kw                Float
  price             Float
  popular           Boolean          @default(false)
  description       String?
  features          String[]
  products          PackageProduct[]
  installationPrice Float            @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

type ProjectSpec {
  label String
  value String
}

model Project {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  slug        String        @unique
  title       String
  category    String        @default("Rezidențial")
  capacity    String        @default("")
  description String
  location    String
  year        Int
  images      String[]
  details     String[]
  specs       ProjectSpec[]
  gridSize    String        @default("normal")
  featured    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AdminUser {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
}
